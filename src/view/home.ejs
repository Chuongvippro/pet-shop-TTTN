<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Thú Cưng Shop</title>
  <link rel="stylesheet" href="/css/home.css">
</head>

<body>
  <header>
    <div class="container">
      <h1>Thú Cưng Shop</h1>
      <nav>
        <ul>
          <li><a href="#">Trang Chủ</a></li>
          <li><a href="#">Sản Phẩm</a></li>
          <li><a href="#">Giới Thiệu</a></li>
          <li><a href="#">Liên Hệ</a></li>
          <% if (user) { %>


            <% if (user.role==='admin' ) { %>
              <li><a href="/admin">Quản trị</a></li>
              <% } %>

                <li><a href="/profile">Xin chào, <%= user.username || user.email %></a></li>
                <li><a href="#" onclick="logout()">Đăng xuất</a></li>

                <% } else { %>
                  <li><a href="/user/login" class="login-btn">Đăng nhập</a></li>
                  <% } %>
        </ul>
      </nav>
    </div>
  </header>

  <section class="hero">
    <div class="container">
      <h2>Chào mừng, <%= name %>!</h2>
      <p>Tìm những người bạn lông xù tuyệt vời cho gia đình bạn!</p>
      <a href="#" class="btn">Xem Sản Phẩm</a>
    </div>
  </section>

  <section class="products">
    <div class="container">
      <h2>Sản Phẩm Nổi Bật</h2>
      <div class="product-list">
        <div class="product-card">
          <img src="https://place-puppy.com/200x200" alt="Chó">
          <h3>Chó con dễ thương</h3>
          <p>Giá: 2.000.000₫</p>
        </div>
        <div class="product-card">
          <img src="https://placekitten.com/200/200" alt="Mèo">
          <h3>Mèo con xinh xắn</h3>
          <p>Giá: 1.500.000₫</p>
        </div>
        <div class="product-card">
          <img src="https://place-puppy.com/201x201" alt="Thú cưng khác">
          <h3>Bồ câu hiền lành</h3>
          <p>Giá: 500.000₫</p>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      <p>&copy; 2026 Thú Cưng Shop. All rights reserved.</p>
    </div>
  </footer>


  <script src="/js/api.js"></script>
  <script src="/js/home.js"></script>

</body>

</html>