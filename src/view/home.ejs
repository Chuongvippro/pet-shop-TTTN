<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Thú Cưng Shop</title>
  <link rel="stylesheet" href="/css/home.css">
</head>

<body>
  <header>
    <div class="container">
      <h1>Thú Cưng Shop</h1>
      <nav>
        <ul>
          <li style="position: relative;">
            <input type="text" id="searchInput" placeholder="Tìm sản phẩm..." />
            <button onclick="handleSearch()">Search</button>
            <div id="searchResult" class="search-result"></div>
          </li>
          <li><a href="#">Trang Chủ</a></li>
          <li class="dropdown">
            <a href="#">Sản Phẩm</a>
            <ul class="dropdown-menu" id="categoryMenu"></ul>
          </li>
          <li><a href="#">Giới Thiệu</a></li>
          <li><a href="#">Liên Hệ</a></li>
          <% if (user) { %>


            <% if (user.role==='admin' ) { %>
              <li><a href="/admin">Quản trị</a></li>
              <% } %>

                <li><a href="/user/profile">Thông tin cá nhân</a></li>
                <li><a href="#" onclick="logout()">Đăng xuất</a></li>

                <% } else { %>
                  <li><a href="/user/login" class="login-btn">Đăng nhập</a></li>
                  <% } %>
        </ul>
      </nav>
    </div>
  </header>



  <section class="products">
    <div class="container">
      <h2>Sản Phẩm Nổi Bật</h2>
      <div class="product-list">
        <a href="/products?category=food" class="product-card">
          <img src="https://place-puppy.com/200x200" alt="Chó">
          <h3>Thức ăn</h3>
        </a>

        <a href="/products?category=cleaning" class="product-card">
          <img src="https://placekitten.com/200/200" alt="Mèo">
          <h3>Dụng cụ vệ sinh</h3>
        </a>

        <a href="/products?category=accessory" class="product-card">
          <img src="https://place-puppy.com/201x201" alt="Thú cưng khác">
          <h3>Phụ kiện</h3>
        </a>
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      <p>&copy; 2026 Thú Cưng Shop. All rights reserved.</p>
    </div>
  </footer>


  <script src="/js/api.js"></script>
  <script src="/js/home.js"></script>

</body>

</html>