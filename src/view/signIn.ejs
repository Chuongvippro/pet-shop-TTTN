<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Đăng ký</title>
    <link rel="stylesheet" href="/css/home.css">

    <style>
        .register-container {
            margin: 100px auto;
            /* Thêm auto để form tự canh giữa màn hình */
            max-width: 400px;
            font-family: sans-serif;
            /* Bạn có thể bỏ dòng này nếu trong home.css đã có */
        }

        .form-title {
            text-align: center;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-input {
            width: 100%;
            padding: 10px;
            box-sizing: border-box;
            /* Giúp input không bị tràn ra ngoài form */
            border: 1px solid #ccc;
            border-radius: 4px;
        }

        .btn-submit {
            width: 100%;
            padding: 10px;
            background-color: #28a745;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            /* Thêm hiệu ứng bàn tay khi trỏ chuột vào nút */
            font-size: 16px;
        }

        .btn-submit:hover {
            background-color: #218838;
            /* Hiệu ứng hover nhẹ cho nút */
        }

        /* CSS cho hộp thoại thông báo */
        .alert-message {
            margin-bottom: 15px;
            padding: 10px;
            border-radius: 5px;
            color: white;
            text-align: center;
        }

        .alert-success {
            background-color: #28a745;
        }

        .alert-error {
            background-color: #dc3545;
        }

        .link-wrapper {
            text-align: center;
            margin-top: 15px;
        }

        .login-link {
            color: #007bff;
            text-decoration: none;
        }

        .login-link:hover {
            text-decoration: underline;
        }

        .msg-success {
            color: green;
            margin-top: 10px;
            font-size: 14px;
            text-align: center;
        }

        .msg-error {
            color: red;
            margin-top: 10px;
            font-size: 14px;
            text-align: center;
        }
    </style>
</head>

<body>

    <div class="register-container">
        <h2 class="form-title">Đăng ký</h2>

        <form method="POST" action="/user/api/signIn">

            <div class="form-group">
                <label>Tên người dùng</label>
                <input type="text" name="username" class="form-input" required
                    value="<%= typeof oldInput !== 'undefined' ? oldInput.username : '' %>">
            </div>

            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" class="form-input" required
                    value="<%= typeof oldInput !== 'undefined' ? oldInput.email : '' %>">
            </div>

            <div class="form-group">
                <label>Mật khẩu</label>
                <input type="password" name="password" class="form-input" required>
            </div>

            <div class="form-group">
                <label>Nhập lại mật khẩu</label>
                <input type="password" name="confirmPassword" class="form-input" required>
            </div>

            <button type="submit" class="btn-submit">Đăng ký</button>

            <% if (typeof message !=='undefined' && message) { %>
                <p class="<%= success ? 'msg-success' : 'msg-error' %>">
                    <%= message %>
                </p>
                <% } %>

                    <div class="link-wrapper">
                        <a href="/user/login" class="login-link">
                            Đã có tài khoản? Đăng nhập
                        </a>
                    </div>

        </form>

    </div>

</body>

</html>